<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Kalau file/folder ada di dist, langsung serve
    RewriteCond %{DOCUMENT_ROOT}/dist%{REQUEST_URI} -f [OR]
    RewriteCond %{DOCUMENT_ROOT}/dist%{REQUEST_URI} -d
    RewriteRule ^ dist%{REQUEST_URI} [L]

    # Kalau tidak ada, fallback ke dist/index.html
    RewriteRule ^ dist/index.html [L]
</IfModule>