<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Jika file atau folder ada, langsung serve
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Kalau tidak ada file/folder, fallback ke index.html di dist
  RewriteRule ^ index.html [L]
</IfModule>
