# Aktifkan rewrite engine
RewriteEngine On

# Hilangkan index.php dari URL
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php/$1 [L]

# Proteksi: blok akses langsung ke file sensitif
<FilesMatch "(composer\.json|composer\.lock|\.env|\.gitignore)">
    Order allow,deny
    Deny from all
</FilesMatch>

# Atur default index
DirectoryIndex index.php
