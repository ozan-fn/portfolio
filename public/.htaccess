<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 1. Jika URL diawali dengan /api, arahkan ke index.php
    RewriteRule ^api index.php [L]

    # 2. Jika request adalah file asli yang ada (js, css, png), ambil langsung
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # 3. Jika BUKAN /api dan file tidak ditemukan, arahkan ke index.html (Build Vite)
    # Ini menangani routing SPA (seperti /dashboard, /profile, dll)
    RewriteRule ^ index.html [L]
</IfModule>